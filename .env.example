# ===================================================================
# Q4NT PRO - Environment Configuration Template
# ===================================================================
# Copy this file to .env and replace placeholder values with real keys.
# NEVER commit .env to version control.
#
# IMPORTANT: All API keys listed here are injected server-side by the
# FastAPI backend. The frontend NEVER handles raw API credentials.
# ===================================================================

# Server Configuration
PORT=8000
ENVIRONMENT=development

# Database / Other Integrations
DB_CONNECTION_STRING=

# -------------------------------------------------------------------------
# LLM / AI Services
# -------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT=60
AI_FAST_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=

# -------------------------------------------------------------------------
# Discord (News Listener)
# -------------------------------------------------------------------------
DISCORD_BOT_TOKEN=

# -------------------------------------------------------------------------
# Cloudflare (Internet Traffic Analysis)
# -------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=

# -------------------------------------------------------------------------
# Mapbox (Globe/Map View)
# -------------------------------------------------------------------------
MAPBOX_TOKEN=

# -------------------------------------------------------------------------
# Polygon.io (Market Data Sync)
# -------------------------------------------------------------------------
POLYGON_API_KEY=

# -------------------------------------------------------------------------
# YouTube (Optional - Transcript Pipeline)
# -------------------------------------------------------------------------
YOUTUBE_API_KEY=

# -------------------------------------------------------------------------
# Logging
# -------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text

# -------------------------------------------------------------------------
# API Server
# -------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=5052

# -------------------------------------------------------------------------
# Alpaca (Trading & Market Data)
# -------------------------------------------------------------------------
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# -------------------------------------------------------------------------
# Charles Schwab (Trading & Market Data - OAuth 2.0)
# -------------------------------------------------------------------------
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:5052/api/schwab/callback
SCHWAB_TOKEN_FILE=schwab_tokens.json

# -------------------------------------------------------------------------
# DraftKings / Sports Betting (Unofficial Public API)
# -------------------------------------------------------------------------
# No key needed for unofficial DraftKings endpoints.
# If using The Odds API as alternative:
# ODDS_API_KEY=

# -------------------------------------------------------------------------
# Plaid (Banking Connection)
# -------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_TOKEN_FILE=plaid_chase_tokens.json

# -------------------------------------------------------------------------
# FRED (Federal Reserve Economic Data)
# -------------------------------------------------------------------------
FRED_API_KEY=

# -------------------------------------------------------------------------
# NASA (Satellite Tracking, APOD, etc.)
# -------------------------------------------------------------------------
NASA_API_KEY=

# -------------------------------------------------------------------------
# OpenWeatherMap (Weather Tile Overlay)
# -------------------------------------------------------------------------
OWM_API_KEY=

# -------------------------------------------------------------------------
# Spotify (Music Data - OAuth 2.0)
# -------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5052/api/spotify/callback
SPOTIFY_TOKEN_FILE=spotify_tokens.json

# -------------------------------------------------------------------------
# TMDb (The Movie Database)
# -------------------------------------------------------------------------
TMDB_API_KEY=
TMDB_READ_TOKEN=

# -------------------------------------------------------------------------
# EIA (Energy Information Administration)
# -------------------------------------------------------------------------
EIA_API_KEY=

# -------------------------------------------------------------------------
# Unusual Whales API
# -------------------------------------------------------------------------
UNUSUAL_WHALES_API_KEY=

# -------------------------------------------------------------------------
# SerpApi (Google Trends)
# -------------------------------------------------------------------------
SERPAPI_API_KEY=
